include CODE_OF_CONDUCT.md
include LICENSE
include README.md

recursive-include docs *.rst *.md *.py *.yaml *.css Makefile make.bat
recursive-include examples *.py *.md
recursive-include scripts *.py *.sh
recursive-include devtools *.md *.yaml *.py
recursive-include benchmarks/reference *.md *.csv *.png
recursive-include standalone/tepid_qsceom/configs *.json *.md
recursive-include standalone/tepid_qsceom/docs *.md
recursive-include standalone/tepid_qsceom/examples *.py *.md

recursive-exclude docs/_build *
recursive-exclude examples/outputs *
recursive-exclude standalone/tepid_qsceom/outputs *
recursive-exclude standalone/tepid_qsceom/examples/outputs *
recursive-exclude standalone/tepid_qsceom/configs/standalone *
recursive-exclude benchmarks/gpu_speedups_* *
recursive-exclude benchmarks/hchain_gpu_capability_* *
recursive-exclude benchmarks/hchain_sector_gpu_capability_* *
recursive-exclude benchmarks/hchain_hybrid_capability_* *
recursive-exclude benchmarks/h8_sector_projection_* *

global-exclude *.py[cod] __pycache__ *.so .DS_Store
